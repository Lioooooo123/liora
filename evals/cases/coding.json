[
  {
    "name": "replace-file-content",
    "input": "读取 app.txt，把其中的 old 精确替换为 new，保留其余内容不变。",
    "files": {
      "app.txt": "hello old agent\n",
      "notes.txt": "do not change\n"
    },
    "expected_files": {
      "app.txt": "hello new agent\n",
      "notes.txt": "do not change\n"
    },
    "expected_tools": ["read", "replace"],
    "forbidden_tools": ["delete"],
    "allowed_changed_files": ["app.txt"],
    "required_successful_tools": ["replace"],
    "max_tool_calls": 3,
    "profiles": ["deterministic", "live"],
    "scripted_steps": [
      {"tool": "read", "arguments": {"path": "app.txt"}},
      {"tool": "replace", "arguments": {"path": "app.txt", "old_text": "old", "new_text": "new"}}
    ]
  },
