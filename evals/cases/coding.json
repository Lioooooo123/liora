      "package/c.txt": "alpha two\n"
    },
    "expected_files": {
      "package/a.txt": "beta one\n",
      "package/b.md": "alpha docs\n",
      "package/c.txt": "beta two\n"
    },
    "expected_tools": ["glob", "read", "replace"],
    "forbidden_tools": ["delete", "write"],
    "allowed_changed_files": ["package/a.txt", "package/c.txt"],
    "required_successful_tools": ["replace"],
    "max_tool_calls": 6,
    "profiles": ["deterministic"],
    "scripted_steps": [
      {"tool": "glob", "arguments": {"pattern": "*.txt", "path": "package"}},
      {"tool": "read", "arguments": {"path": "package/a.txt"}},
      {"tool": "read", "arguments": {"path": "package/c.txt"}},
      {"tool": "replace", "arguments": {"path": "package/a.txt", "old_text": "alpha", "new_text": "beta"}},
      {"tool": "replace", "arguments": {"path": "package/c.txt", "old_text": "alpha", "new_text": "beta"}}
    ]
  },
