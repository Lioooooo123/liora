{
  "version": "2026-06-30.task-events.v1",
  "contract_version": "2026-06-30.task-events.v1",
  "single_task_stream": [
    {
      "event": "task.created",
      "id": "event-001",
      "data": {
        "message": "created",
        "risk": "safe",
        "origin": "background",
        "kind": "background",
        "source": "fixture",
        "trigger": "manual-smoke"
      }
    },
    {
      "event": "tool.call",
      "id": "event-002",
      "data": {
        "tool": "read",
        "tool_call_id": "fixture-call-1",
        "input": "README.md"
      }
    },
    {
      "event": "tool.result",
      "id": "event-003",
      "data": {
        "tool": "read",
        "tool_call_id": "fixture-call-1",
        "tool_result_id": "fixture-call-1-result",
        "output": "Liora"
      }
    },
    {
      "event": "task.completed",
      "id": "event-004",
      "data": {
        "status": "completed"
      }
    }
  ],
  "multi_task_stream": [
    {
      "event": "task.summary",
      "id": "event-101",
      "data": {
        "task_id": "task-002",
        "payload": {
          "message": "background summary"
        }
      }
    },
    {
      "event": "permission.requested",
      "id": "event-102",
      "data": {
        "task_id": "task-003",
        "payload": {
          "tool": "run",
          "risk": "dangerous_shell",
          "reason": "requires approval",
          "origin": "schedule",
          "kind": "schedule",
          "source": "cron:nightly",
          "trigger": "0 2 * * *"
        }
      }
    }
  ],
  "multi_thread_stream": [
    {
      "event": "thread_message.received",
      "id": "event-201",
      "data": {
        "thread_id": "thread-002",
        "task_id": "task-004",
        "payload": {
          "message": "handoff received"
        }
      }
    }
  ],
  "error_response": {
    "status": 404,
    "error": "task not found"
  }
}
